target/
**/target/
*.rs.bk
# Cargo.lock is intentionally COMMITTED for the binary-producing runtime workspace
# so clean clones resolve byte-identical pinned dependencies (Determinism/Replay).
# See runtime/rcr/RCR-001.md (item #7). Do NOT re-ignore it.
__pycache__/
*.pyc

# arves init scaffolds — keep the curated examples/, ignore ad-hoc scaffolds anywhere else
*.capability.mjs
!products/arves-ecosystem-sdk/examples/*.capability.mjs
/hello-arves.mjs

# local capability registry (arves publish/install) — runtime data, not source
/.arves-registry/

# TLA+ tooling — the 2.3 MB tla2tools.jar is downloaded, not committed (see
# verification/formal/TLC_RUN.md for the pinned URL + sha256); states/ is TLC scratch
verification/formal/tla2tools.jar
verification/formal/states/
