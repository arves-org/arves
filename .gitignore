target/
**/target/
*.rs.bk
# Cargo.lock is intentionally COMMITTED for the binary-producing runtime workspace
# so clean clones resolve byte-identical pinned dependencies (Determinism/Replay).
# See runtime/rcr/RCR-001.md (item #7). Do NOT re-ignore it.
__pycache__/
*.pyc

# arves init scaffolds — keep the curated examples/, ignore ad-hoc scaffolds anywhere else
*.capability.mjs
!products/arves-ecosystem-sdk/examples/*.capability.mjs
/hello-arves.mjs

# local capability registry (arves publish/install) — runtime data, not source
/.arves-registry/

# TLA+ tooling — the 2.3 MB tla2tools.jar is downloaded, not committed (see
# verification/formal/TLC_RUN.md for the pinned URL + sha256); states/ is TLC scratch
verification/formal/tla2tools.jar
verification/formal/states/

# runtime/review-input/ — LOCAL derivative .txt conversions of the frozen corpus used by
# review tooling; never committed (the corpus .docx + spec-markdown mirrors are the frozen
# sources of record). Ignored so they can never re-enter the freeze manifest by accident.
runtime/review-input/

# JARVIS local memory — the WAL directory the assistant/console writes your truth into
# (node ui/server.mjs --wal-dir …, `npm run ui`, and the quickstart). Runtime data on YOUR
# machine, never source; ignored so a demo run can never stage your personal truth.
jarvis-wal/
**/jarvis-wal/
my-jarvis-wal/
**/my-jarvis-wal/
